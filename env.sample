# Backend selection
AGENT_KIND=local

# Foundry agent settings (required for local tool and foundry mode)
AZURE_AI_PROJECT_ENDPOINT=https://your-project-name.services.ai.azure.com/api/projects/your-project-name
AZURE_AI_PROJECT_AGENT_NAME=AgentSmith
# AZURE_AI_PROJECT_AGENT_VERSION=1.0
# AZURE_AI_PROJECT_AGENT_DESCRIPTION=Ask the Foundry agent a question

# Local agent Azure OpenAI settings
AZURE_OPENAI_CHAT_DEPLOYMENT_NAME=gpt-5-mini
AZURE_OPENAI_ENDPOINT=https://your-resource-name.cognitiveservices.azure.com/openai/deployments/gpt-5-mini/chat/completions?api-version=2024-05-01-preview
AZURE_OPENAI_API_KEY=your-azure-openai-api-key

# Optional frontend proxy target
# AG_UI_ENDPOINT=http://localhost:8000/ag-ui

# Optional frontend UI text
NEXT_PUBLIC_IMPROVE_BUTTON_LABEL=Improve with AI
NEXT_PUBLIC_IMPROVE_PROMPT=Improve the project

# Optional server settings
# HOST=0.0.0.0
# PORT=8000

# Logging
# ENABLE_DEBUG_LOGGING=1
